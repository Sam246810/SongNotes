# Copy this file to .env.local and fill in your own free Supabase project's values.
# Create a project at https://supabase.com, then find these under
# Project Settings -> API. The anon key is safe to expose in a client bundle —
# Row Level Security policies (see supabase/schema.sql) are what actually scope
# access to each user's own rows.
#
# Without these set, SongNotes still works fully in local guest mode (no
# accounts, no cloud sync) — accounts/sync are simply disabled.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
